[push]
	default = simple
[core]
	trustctime = false
	editor = nvim
	filemode = false
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[color]
	ui = true
[credential]
	helper = store
[merge]
	tool = nvimdiff
[mergetool]
	keeptemporaries = false
	keepbackups = false
	prompt = false
	trustexitcode = false
[alias]
	last = log -1 --stat
	cp = cherry-pick
	co = checkout
	cl = clone
	ci = commit
	st = status -sb
	br = branch
	unstage = reset HEAD --
	dc = diff --cached
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %Cblue<%an>%Creset' --abbrev-commit --date=relative --all

[http]
	sslCAinfo = /etc/ssl/certs/ca-certificates.crt
[user]
	email = 12martin12@gmx.de
	name = iNETSOLDIER
[init]
	defaultBranch = main
